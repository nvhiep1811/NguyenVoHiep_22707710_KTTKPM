# Infrastructure
# MONGO_PORT is only used when running the optional local MongoDB container.
MONGO_PORT=27017
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MongoDB Atlas
# 1. Create a database user in Atlas.
# 2. Allow your IP address in Network Access.
# 3. Copy your cluster host, for example: cluster0.abcde.mongodb.net.
# 4. URL-encode the password if it contains special characters.
MONGO_ATLAS_USERNAME=your_atlas_username
MONGO_ATLAS_PASSWORD=your_url_encoded_atlas_password
MONGO_ATLAS_CLUSTER=cluster0.xxxxx.mongodb.net
MONGO_ATLAS_APP_NAME=MovieTicketEventDriven

# Kafka topics
TOPIC_BOOKING_CREATED=BOOKING_CREATED
TOPIC_PAYMENT_COMPLETED=PAYMENT_COMPLETED
TOPIC_BOOKING_FAILED=BOOKING_FAILED

# Payment Service
PAYMENT_SERVER_PORT=8083
PAYMENT_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/payment_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
PAYMENT_KAFKA_CONSUMER_GROUP=payment-service
PAYMENT_SUCCESS_RATE=0.8

# Notification Service
NOTIFICATION_SERVER_PORT=8084
NOTIFICATION_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/notification_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
NOTIFICATION_KAFKA_CONSUMER_GROUP=notification-service

# Optional local Mongo fallback:
# PAYMENT_MONGODB_URI=mongodb://localhost:27017/payment_db
# NOTIFICATION_MONGODB_URI=mongodb://localhost:27017/notification_db
