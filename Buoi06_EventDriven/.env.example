# Infrastructure
# MONGO_PORT is only used when running the optional local MongoDB container.
MONGO_PORT=27017
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RETRY_MAX_ATTEMPTS=3
KAFKA_RETRY_BACKOFF_MS=1000
VITE_API_BASE=http://localhost:8080/api
FRONTEND_HOST_PORT=3000
GATEWAY_HOST_PORT=8080
GATEWAY_SERVER_PORT=8080
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:8080,http://127.0.0.1:5173,http://127.0.0.1:4173

# Gateway upstreams.
# For LAN deployment, replace these values with http://<machine-ip>:<service-port>.
USER_SERVICE_URI=http://user-service:8081
MOVIE_SERVICE_URI=http://movie-service:8082
BOOKING_SERVICE_URI=http://booking-service:8085
PAYMENT_SERVICE_URI=http://payment-service:8083
NOTIFICATION_SERVICE_URI=http://notification-service:8084
FRONTEND_URI=http://frontend:80

# MongoDB Atlas
# 1. Create a database user in Atlas.
# 2. Allow your IP address in Network Access.
# 3. Copy your cluster host, for example: cluster0.abcde.mongodb.net.
# 4. URL-encode the password if it contains special characters.
MONGO_ATLAS_USERNAME=your_atlas_username
MONGO_ATLAS_PASSWORD=your_url_encoded_atlas_password
MONGO_ATLAS_CLUSTER=cluster0.xxxxx.mongodb.net
MONGO_ATLAS_APP_NAME=MovieTicketEventDriven

# Kafka topics
TOPIC_USER_REGISTERED=USER_REGISTERED
TOPIC_BOOKING_CREATED=BOOKING_CREATED
TOPIC_PAYMENT_COMPLETED=PAYMENT_COMPLETED
TOPIC_BOOKING_FAILED=BOOKING_FAILED

# User Service
USER_HOST_PORT=18081
USER_SERVER_PORT=8081
USER_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/user_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
USER_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
USER_KAFKA_CONSUMER_GROUP=user-service

# Movie Service
MOVIE_HOST_PORT=18082
MOVIE_SERVER_PORT=8082
MOVIE_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/movie_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
MOVIE_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
MOVIE_KAFKA_CONSUMER_GROUP=movie-service

# Booking Service
BOOKING_HOST_PORT=18085
BOOKING_SERVER_PORT=8085
BOOKING_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/booking_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
BOOKING_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
BOOKING_KAFKA_CONSUMER_GROUP=booking-service

# Payment Service
PAYMENT_HOST_PORT=18083
PAYMENT_SERVER_PORT=8083
PAYMENT_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/payment_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
PAYMENT_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
PAYMENT_KAFKA_CONSUMER_GROUP=payment-service
PAYMENT_SUCCESS_RATE=0.8

# Notification Service
NOTIFICATION_HOST_PORT=18084
NOTIFICATION_SERVER_PORT=8084
NOTIFICATION_MONGODB_URI=mongodb+srv://${MONGO_ATLAS_USERNAME}:${MONGO_ATLAS_PASSWORD}@${MONGO_ATLAS_CLUSTER}/notification_db?retryWrites=true&w=majority&appName=${MONGO_ATLAS_APP_NAME}
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
NOTIFICATION_KAFKA_CONSUMER_GROUP=notification-service

# Optional local Mongo fallback:
# USER_MONGODB_URI=mongodb://localhost:27017/user_db
# MOVIE_MONGODB_URI=mongodb://localhost:27017/movie_db
# BOOKING_MONGODB_URI=mongodb://localhost:27017/booking_db
# PAYMENT_MONGODB_URI=mongodb://localhost:27017/payment_db
# NOTIFICATION_MONGODB_URI=mongodb://localhost:27017/notification_db
