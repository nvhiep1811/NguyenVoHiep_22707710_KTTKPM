# Machine 1: Frontend + Spring Cloud Gateway + Kafka
# Replace these IPs with your real LAN addresses.

# MongoDB Atlas, kept here because docker compose interpolates every service.
MONGO_ATLAS_USERNAME=your_atlas_username
MONGO_ATLAS_PASSWORD=your_url_encoded_atlas_password
MONGO_ATLAS_CLUSTER=cluster0.xxxxx.mongodb.net
MONGO_ATLAS_APP_NAME=MovieTicketEventDriven

KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=192.168.1.10
KAFKA_BOOTSTRAP_SERVERS=192.168.1.10:9092

GATEWAY_HOST_PORT=8080
GATEWAY_SERVER_PORT=8080
FRONTEND_HOST_PORT=3000
VITE_API_BASE=http://192.168.1.10:8080/api

USER_SERVICE_URI=http://192.168.1.11:8081
MOVIE_SERVICE_URI=http://192.168.1.12:8082
BOOKING_SERVICE_URI=http://192.168.1.13:8085
PAYMENT_SERVICE_URI=http://192.168.1.14:8083
NOTIFICATION_SERVICE_URI=http://192.168.1.14:8084
FRONTEND_URI=http://frontend:80

CORS_ALLOWED_ORIGIN_PATTERNS=http://192.168.1.10:8080,http://192.168.1.10:3000,http://localhost:8080,http://localhost:3000
