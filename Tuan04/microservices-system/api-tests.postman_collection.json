{
  "info": {
    "name": "Microservices API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8090"
    },
    {
      "key": "username",
      "value": "hiep_api"
    },
    {
      "key": "password",
      "value": "123456"
    },
    {
      "key": "userId",
      "value": "3"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register Auth User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{username}}@gmail.com\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/auth/register",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400 (already exists)', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/auth/login",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.accessToken);",
              "pm.test('Access token is present', function () {",
              "  pm.expect(data.accessToken).to.be.a('string').and.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Get Auth Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayUrl}}/auth/users",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Create User Profile (JWT required)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}},\n  \"fullName\": \"Hiep API\",\n  \"phone\": \"0900000000\",\n  \"address\": \"Ho Chi Minh\",\n  \"dateOfBirth\": \"2003-05-10\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/users/profiles",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "users",
            "profiles"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 400 (already exists)', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Get Profile By UserId (JWT required)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayUrl}}/users/profiles/{{userId}}",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "users",
            "profiles",
            "{{userId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Unauthorized Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{gatewayUrl}}/users/profiles/{{userId}}",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "users",
            "profiles",
            "{{userId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 without token', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
